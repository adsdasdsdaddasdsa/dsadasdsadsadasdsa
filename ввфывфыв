    local FillW, FillH = math.ceil(Current / Max * BarW), BarH

    if Pos > 2 then
        BarW, BarH = 4, math_floor( MaxY - MinY ) + 2
        FillW, FillH = BarW, math.ceil(Current / Max * BarH)
    end

    FillW = math.min(FillW, BarW)
    FillH = math.min(FillH, BarH)

    surface_SetDrawColor(BackColor)
    surface_DrawRect(BarX, BarY, BarW, BarH)

    BarX, BarY = BarX + 1, BarY + 1

    if Pos > 2 then
        BarY = BarY + BarH - FillH
    end

    BarW, BarH = BarW - 2, BarH - 2
    FillW, FillH = FillW - 2, FillH - 2

    surface_SetDrawColor(BarColor)
    surface_DrawRect(BarX, BarY, FillW, FillH)

    if Gradient then
        surface_SetDrawColor(GradientColor)
        surface_SetMaterial(ultimate.Materials["Gradient"])
        surface_DrawTexturedRect(BarX, BarY, FillW, FillH)
    end
end

function ultimate.DrawKnifebotRange()
    if not ultimate.cfg.vars["Knifebot"] or not ultimate.cfg.vars["Knifebot range circle"] then
        return
    end

    local me = LocalPlayer()
    local weapon = me:GetActiveWeapon()

    if not IsValid(weapon) or not IsValid(me) then return end

    local wc = weapon:GetClass()
    local is_knife = false
    for i = 1, #ultimate.knifes do
        if StartsWith(wc, ultimate.knifes[i].str) then
            is_knife = true
            break
        end
    end

    if not is_knife then return end

    local distance = ultimate.cfg.vars["Knifebot distance"]
    local center = me:GetPos()
    local segments = 64
    local color = string_ToColor(ultimate.cfg.colors["Knifebot range circle"])

    local angle_step = (2 * math.pi) / segments

    for i = 1, segments do
        local angle1 = angle_step * (i - 1)
        local angle2 = angle_step * i

        local x1 = center.x + math.cos(angle1) * distance
        local y1 = center.y + math.sin(angle1) * distance

        local x2 = center.x + math.cos(angle2) * distance
        local y2 = center.y + math.sin(angle2) * distance

        local pos1 = Vector(x1, y1, center.z)
        local pos2 = Vector(x2, y2, center.z)

        local screen1 = pos1:ToScreen()
        local screen2 = pos2:ToScreen()

        if screen1.visible and screen2.visible then
            surface.SetDrawColor(color.r, color.g, color.b, color.a)
            surface.DrawLine(screen1.x, screen1.y, screen2.x, screen2.y)
        end
    end

    local inner_distance = distance - 5
    for i = 1, segments do
        local angle1 = angle_step * (i - 1)
        local angle2 = angle_step * i

        local x1 = center.x + math.cos(angle1) * inner_distance
        local y1 = center.y + math.sin(angle1) * inner_distance

        local x2 = center.x + math.cos(angle2) * inner_distance
        local y2 = center.y + math.sin(angle2) * inner_distance

        local pos1 = Vector(x1, y1, center.z)
        local pos2 = Vector(x2, y2, center.z)

        local screen1 = pos1:ToScreen()
        local screen2 = pos2:ToScreen()

        if screen1.visible and screen2.visible then
            surface.SetDrawColor(color.r, color.g, color.b, color.a * 0.5)
            surface.DrawLine(screen1.x, screen1.y, screen2.x, screen2.y)
        end
    end
end

