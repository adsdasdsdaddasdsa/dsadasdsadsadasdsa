local function TimedSwitch(interval)
    if CurTime() - ultimate.aa.lastSwitch > interval then
        ultimate.aa.lastSwitch = CurTime()
        ultimate.aa.switchState = not ultimate.aa.switchState
    end
    return ultimate.aa.switchState
end

local function GetNearestEnemy()
    local closest = nil
    local closestDist = math.huge

    for _, ply in ipairs(player.GetAll()) do
        if ply == me then continue end
        if not ply:Alive() then continue end
        if ply:Team() == me:Team() then continue end

        local dist = me:GetPos():DistToSqr(ply:GetPos())
        if dist < closestDist then
            closestDist = dist
            closest = ply
        end
    end

    return closest, math.sqrt(closestDist)
end

local function FreestandAngle()
    local enemy = GetNearestEnemy()
    if not enemy then return baseyaw - 180 end

    local enemyPos = enemy:GetPos()
    local myPos = me:GetPos()
    local angleToEnemy = (enemyPos - myPos):Angle().y

    local leftAngle = math_NormalizeAngle(angleToEnemy + 90)
    local rightAngle = math_NormalizeAngle(angleToEnemy - 90)

    local leftTrace = util.TraceLine({
        start = myPos + Vector(0, 0, 64),
        endpos = myPos + Vector(0, 0, 64) + Angle(0, leftAngle, 0):Forward() * 200,
        filter = me
    })

    local rightTrace = util.TraceLine({
        start = myPos + Vector(0, 0, 64),
        endpos = myPos + Vector(0, 0, 64) + Angle(0, rightAngle, 0):Forward() * 200,
        filter = me
    })

    if leftTrace.Fraction < rightTrace.Fraction then
        return leftAngle
    else
        return rightAngle
    end
end

local function SwitchAAOnHit()
    if not ultimate.cfg.vars["AA switch on hit"] then return end
    
    local curTime = CurTime()
    
    -- Инициализируем таймер, если его нет
    ultimate.aa.lastHitTime = ultimate.aa.lastHitTime or 0
    ultimate.aa.switchLogs = ultimate.aa.switchLogs or {}

    if curTime - ultimate.aa.lastHitTime < ultimate.cfg.vars["AA switch delay"] then
        return
    end
    
    local selectedPresets = {}
    
    -- Правильно читаем значения, которые сохранил MultiCombo
    for idx, name in ipairs(ultimate.presets["Yaw"]) do
        if ultimate.cfg.vars["AA switch presets-" .. name] == true then
            table_insert(selectedPresets, {idx = idx, name = name})
        end
    end
    
    -- Если выбраны пресеты, меняем АА
    if #selectedPresets > 0 then
        ultimate.aa.lastHitTime = curTime
        ultimate.aa.hitSwitchActive = true

        local randomIdx = math_random(1, #selectedPresets)
        local selected = selectedPresets[randomIdx]
        
        -- Применяем новый Yaw
        ultimate.cfg.vars["Yaw"] = selected.idx
        
        -- Добавляем лог
        if ultimate.cfg.vars["AA switch logs"] then
            local logData = {
                text = "AA switched to: " .. selected.name,
                time = curTime,
                alpha = 255
            }
            table_insert(ultimate.aa.switchLogs, logData)
        end
    end
end

