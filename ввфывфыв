ultimate.killstreak_notifications = {}
ultimate.multikill_count = 0
ultimate.multikill_time  = 0

function ultimate.AddKillstreakNotification(ksdata, victimNick)
    ultimate.killstreak_notifications = {}

    local sub = ksdata.sub
    if sub and victimNick then
        sub = sub:format(victimNick)
    end

    table.insert(ultimate.killstreak_notifications, {
        main      = ksdata.main,
        sub       = sub,
        mainColor = ksdata.mainColor,
        startTime = CurTime(),
        duration  = 3.5,
        alpha     = 0,
        scale     = 0.5,
        shake     = ksdata.shake or false,
    })
end

function ultimate.entity_killed(data)
    local aid = Entity(data.entindex_attacker)
    local vid = Entity(data.entindex_killed)

    if aid == me and aid ~= vid and !vid:IsNPC() and (vid:IsPlayer() or vid:IsBot()) then

        ultimate.killstreak = (ultimate.killstreak or 0) + 1
        
        SwitchAAOnHit()

        local now = CurTime()
        if now - (ultimate.multikill_time or 0) < 18 then
            ultimate.multikill_count = (ultimate.multikill_count or 0) + 1
        else
            ultimate.multikill_count = 1
        end
        ultimate.multikill_time = now

        if ultimate.cfg.vars["Killsay"] then
            local chatPrefixes = { [2] = "/ooc ", [3] = "/ad " }
            local prefix = chatPrefixes[ultimate.cfg.vars["Killsay group"]] or ""
            local tbl = ultimate.chatmsg[ultimate.cfg.vars["Killsay mode"]]
            local str = prefix .. tbl[math_random(1, #tbl)]
            if str:find("%s") then str = str:format(vid:Nick()) end
            gRunCmd("say", str)
        end

        -- KILLSOUND
        if ultimate.cfg.vars["Killsound"] then
            surface_PlaySound(ultimate.cfg.vars["Killsound str"])
        end

        -- KILLSTREAK
        if ultimate.cfg.vars["Killstreak"] then
            local mk = ultimate.multikill_count
            local ks = ultimate.killstreak
            local ksdata = nil

            if mk >= 2 and mk <= 5 then
                ksdata = ultimate.killstreak_data[mk]
            elseif ks >= 3 then
                local idx = math.min(ks, 10)
                ksdata = ultimate.killstreak_data[idx]
            end

            if ksdata then
                surface.PlaySound(ksdata.sound)
                ultimate.AddKillstreakNotification(ksdata, me:Nick())
            end
        end

    end
end

