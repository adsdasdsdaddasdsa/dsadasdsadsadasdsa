function ultimate.MovementFix( cmd, wish_yaw )
	local pitch = math_NormalizeAngle( cmd:GetViewAngles().x )
	local sign = ( pitch > 89 || pitch < -89 ) && 1 || -1

	local delta_yaw = math_rad( math_NormalizeAngle( ( cmd:GetViewAngles().y - wish_yaw )*sign ) )

	local forwardmove = cmd:GetForwardMove()
	local sidemove = cmd:GetSideMove()

	local new_forwardmove = forwardmove*-math_cos( delta_yaw )*sign + sidemove*math_sin( delta_yaw )
	local new_sidemove = forwardmove*math_sin( delta_yaw )*sign + sidemove*math_cos( delta_yaw )

	cmd:SetForwardMove( new_forwardmove )
	cmd:SetSideMove( new_sidemove )
end

