function ultimate.CustomSpread.swb( cmd, ang )

    local vel = me:GetVelocity():Length()
    local dir = ang:Forward()

    if ultimate.activeWeapon.dt and ultimate.activeWeapon.AimSpread and ultimate.activeWeapon.dt.State == SWB_AIMING then
        ultimate.activeWeapon.BaseCone = ultimate.activeWeapon.AimSpread

        if ultimate.activeWeapon.Owner.Expertise then
            ultimate.activeWeapon.BaseCone = ultimate.activeWeapon.BaseCone * ( 1 - ultimate.activeWeapon.Owner.Expertise["steadyme"].val * 0.0015 )
        end
    else
        ultimate.activeWeapon.BaseCone = ultimate.activeWeapon.HipSpread

        if ultimate.activeWeapon.Owner.Expertise then
            ultimate.activeWeapon.BaseCone = ultimate.activeWeapon.BaseCone * ( 1 - ultimate.activeWeapon.Owner.Expertise["wepprof"].val * 0.0015 )
        end
    end

    if me:Crouching() then
        ultimate.activeWeapon.BaseCone = ultimate.activeWeapon.BaseCone * ( ultimate.activeWeapon.dt.State == SWB_AIMING and 0.9 or 0.75 )
    end

    local updatetime = ultimate.activeWeapon.GetSpreadUpdateTime(unpredicted)
    local value = ultimate.activeWeapon.GetSpreadUpdateValue(unpredicted)

    if updatetime > 0 then
        value = math_Clamp(value - 0.1333 * (CurTime() - updatetime), 0, ultimate.activeWeapon.MaxSpreadInc)
    end

    local value2 = math_Clamp(ultimate.activeWeapon.GetViewAffinity(unpredicted) - (ultimate.activeWeapon.ShotgunReload and 0.13 or 0.18) * (CurTime() - ultimate.activeWeapon.GetViewAffinityTime()) / ultimate.activeWeapon.FireDelay, 0, 2)

    ultimate.activeWeapon.CurCone = math_Clamp( ultimate.activeWeapon.BaseCone + value + ( vel / 10000 * ultimate.activeWeapon.VelocitySensitivity ) * ( ultimate.activeWeapon.dt.State == SWB_AIMING and ultimate.activeWeapon.meMobilitySpreadMod or 1 ) + value2, 0, 0.09 + ultimate.activeWeapon.MaxSpreadInc )

    local cone = ultimate.activeWeapon.CurCone
    if !cone then return ang end

    if me:Crouching() then
		cone = cone * 0.85
	end

    math_randomseed( cmd:CommandNumber() )

    local dir1 = Angle( math_Rand( -cone, cone ), math_Rand( -cone, cone ), 0 ) * 25
    local dir2 = dir1

    if ultimate.activeWeapon.ClumpSpread and ultimate.activeWeapon.ClumpSpread > 0 then
        dir2 = dir1 + Angle( math_Rand(-1, 1), math_Rand(-1, 1), math_Rand(-1, 1)) * ultimate.activeWeapon.ClumpSpread
    end

    return ang - dir2
end

function ultimate.CustomSpread.cw( cmd, ang )
    if not ultimate.activeWeapon.AccuracyEnabled then
	    return
	end

	local aim = ang:Forward()
	local CT = CurTime()
	local dt = TickInterval

	if !me.LastView then
		me.LastView = aim
		me.ViewAff = 0
	else
		me.ViewAff = LerpCW20(dt * 10, me.ViewAff, (aim - me.LastView):Length() * 0.5)
		me.LastView = aim
	end

	local baseCone, maxSpreadMod = ultimate.activeWeapon:getBaseCone()
	ultimate.activeWeapon.BaseCone = baseCone

	if me:Crouching() then
	    ultimate.activeWeapon.BaseCone = ultimate.activeWeapon.BaseCone * ultimate.activeWeapon:getCrouchSpreadModifier()
    end

	ultimate.activeWeapon.CurCone = ultimate.activeWeapon:getFinalSpread(me:GetVelocity():Length2D(), maxSpreadMod)

	if CT > ultimate.activeWeapon.SpreadWait then
		ultimate.activeWeapon.AddSpread = math_Clamp(ultimate.activeWeapon.AddSpread - 0.5 * ultimate.activeWeapon.AddSpreadSpeed * dt, 0, ultimate.activeWeapon:getMaxSpreadIncrease(maxSpreadMod))
		ultimate.activeWeapon.AddSpreadSpeed = math_Clamp(ultimate.activeWeapon.AddSpreadSpeed + 5 * dt, 0, 1)
	end

	local cone = ultimate.activeWeapon.CurCone
	if !cone then return ang end

	if me:Crouching() then
		cone = cone * 0.85
	end

	math_randomseed( cmd:CommandNumber() )
	return ang - Angle( math_Rand(-cone, cone), math_Rand(-cone, cone), 0 ) * 25
end

