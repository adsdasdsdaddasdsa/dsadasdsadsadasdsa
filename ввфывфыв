                and lby + 180 + math_sin(ct * 12) * 10
                or lby + 58 * side
        else
            -- Стоя: LBY break + desync rotation
            if not ultimate.SendPacket then
                local breakDelta = 120 + math_sin(ct * 3) * 30
                if math_abs(math_NormalizeAngle(lbyTarget - ultimate.oldYaw)) < 30 then
                    return math_NormalizeAngle(
                        ultimate.oldYaw + breakDelta * side
                    )
                else
                    return math_NormalizeAngle(
                        lby - 58 * side + math_sin(ct * 10) * 10
                    )
                end
            else
                return baseyaw - 178 + math_sin(ct * 8) * 5
            end
        end
    end,

    -- ============================================
    -- [40] GHOST WALK
    -- Модель "плывёт" - мягкие плавные
    -- переходы между углами
    -- ============================================
    [40] = function(cmd)
        local ct = CurTime()
        local side = GetSide()

        local wave1 = math_sin(ct * 2.5) * 90
        local wave2 = math_sin(ct * 1.7) * 45
        local wave3 = math_cos(ct * 3.3) * 30

        local ghostAngle = wave1 + wave2 * 0.5 + wave3 * 0.25

        return ultimate.SendPacket
            and baseyaw + ghostAngle
            or baseyaw + ghostAngle + 58 * side
    end,

    -- ============================================
    -- [41] RESOLVER BREAKER
    -- Специально создан чтобы ломать резолверы:
    -- непредсказуемая дельта + LBY abuse
    -- ============================================
    [41] = function(cmd)
        local ct = CurTime()
        local side = GetSide()
        local lby = GetLBY()

        -- Каждые 0.4-0.8 сек меняем паттерн
        if ct - ultimate.aa.lastAntiResolve > 0.4 + math_random() * 0.4 then
            ultimate.aa.lastAntiResolve = ct
            ultimate.aa.antiResolveState = (ultimate.aa.antiResolveState + 1) % 5
        end

        local state = ultimate.aa.antiResolveState

        if state == 0 then
            -- Backward + max desync
            return ultimate.SendPacket
                and baseyaw - 178
                or baseyaw - 178 + 58 * side
        elseif state == 1 then
            -- LBY abuse
            return ultimate.SendPacket
                and lby + 180
                or lby + 58 * side
        elseif state == 2 then
            -- Sideways opposite
            return ultimate.SendPacket
                and baseyaw + 90 * side
                or baseyaw - 90 * side
        elseif state == 3 then
            -- Zero desync bait
            return ultimate.SendPacket
                and baseyaw - 178
                or baseyaw - 178 + math_sin(ct * 30) * 3
        else
            -- Random delta
            local randDelta = math_random(20, 58) * side
            return ultimate.SendPacket
                and baseyaw - 178
                or baseyaw + randDelta
        end
    end,

    -- ============================================
    -- [42] SPIN DESYNC
    -- Спин на real, backward на fake
    -- максимально сложно для хитскана
    -- ============================================
    [42] = function(cmd)
        local ct = CurTime()
        local spinSpeed = 300
        local spin = math_NormalizeAngle(ct * spinSpeed)
        local micro = math_sin(ct * 40) * 5

        return ultimate.SendPacket
            and spin + micro
            or baseyaw - 178 + micro * -1
    end,

    -- ============================================
    -- [43] PEEK AA
    -- Оптимизировано для пиков:
    -- меняет сторону при движении
    -- ============================================
    [43] = function(cmd)
        local ct = CurTime()
        local vel = me:GetVelocity()
        local vel2d = vel:Length2D()
        local side = GetSide()

        if vel2d > 50 then
            -- Определяем направление движения
            local moveAngle = vel:Angle().y
            local diff = math_NormalizeAngle(moveAngle - baseyaw)

            if diff > 0 then
                -- Двигаемся вправо
                return ultimate.SendPacket
                    and baseyaw + 90
                    or baseyaw - 90
            else
                -- Двигаемся влево
                return ultimate.SendPacket
                    and baseyaw - 90
                    or baseyaw + 90
            end
        else
            -- Стоим: backward + desync
            return ultimate.SendPacket
                and baseyaw - 178
                or baseyaw + 58 * side
        end
    end,

    -- ============================================
    -- [44] QUANTUM JITTER
    -- Случайные квантовые "прыжки" между
    -- несколькими состояниями
    -- ============================================
    [44] = function(cmd)
        local ct = CurTime()
        local side = GetSide()

        -- "Квантовые" прыжки
        local quantum1 = math.floor(ct * 8) % 7
        local quantum2 = math.floor(ct * 13) % 5
        local quantum3 = math.floor(ct * 21) % 3

        local qOffset = (quantum1 - 3) * 25 + (quantum2 - 2) * 15 + (quantum3 - 1) * 10
        local micro = math_sin(ct * 50) * 2

        return ultimate.SendPacket
            and baseyaw - 178 + qOffset * 0.3 + micro
            or baseyaw + qOffset + 58 * side + micro * -1
    end,

    -- ============================================
    -- [45] HEARTBEAT AA
    -- Имитирует паттерн сердцебиения:
    -- два быстрых "удара" и пауза
    -- ============================================
    [45] = function(cmd)
        local ct = CurTime()
        local side = GetSide()

        local heartbeat = ct % 1.2

        local offset
        if heartbeat < 0.1 then
            -- Первый удар
            offset = 58 * side
        elseif heartbeat < 0.2 then
            -- Возврат
            offset = 0
        elseif heartbeat < 0.3 then
            -- Второй удар
            offset = -58 * side
        else
            -- Пауза
            offset = math_sin(ct * 5) * 5
        end

        return ultimate.SendPacket
            and baseyaw - 178 + offset
            or baseyaw - 178 + offset * -1 + 58 * side
    end,

    -- ============================================
    -- [46] MATRIX AA
    -- Многослойная система с тремя
    -- независимыми осцилляторами
    -- ============================================
    [46] = function(cmd)
        local ct = CurTime()
        local side = GetSide()

        -- Три независимых слоя
        local layer1 = math_sin(ct * 3.7) * 40
        local layer2 = math_sin(ct * 7.3 + 1.5) * 25
        local layer3 = math_sin(ct * 13.1 + 3.0) * 15

        -- XOR-подобная комбинация
        local combined = layer1
        if math_sin(ct * 5) > 0 then
            combined = combined + layer2
        else
            combined = combined - layer2
        end

        if math_cos(ct * 8) > 0 then
            combined = combined + layer3
        else
            combined = combined - layer3
        end

        return ultimate.SendPacket
            and baseyaw + combined
            or baseyaw + combined * -0.7 + 58 * side
    end,

    -- ============================================
    -- [47] FREESTAND JITTER
    -- Freestanding + jitter для максимальной
    -- защиты за укрытием
    -- ============================================
    [47] = function(cmd)
        local ct = CurTime()
        local side = GetSide()
        local freeYaw = FreestandAngle()
        local jitter = math_sin(ct * 20) * 25
        local micro = math_sin(ct * 45) * 5

        return ultimate.SendPacket
            and freeYaw + jitter + micro
            or freeYaw + 180 + micro * -1
    end,

    -- ============================================
    -- [48] STATIC DESYNC SWITCH
    -- Переключение между двумя статическими
    -- десинк-позициями
    -- ============================================
    [48] = function(cmd)
        local ct = CurTime()
        local side = GetSide()

        local switchInterval = 0.6
        local switched = TimedSwitch(switchInterval)

        if switched then
            return ultimate.SendPacket
                and baseyaw - 178
                or baseyaw + 58 * side
        else
            return ultimate.SendPacket
                and baseyaw - 178
                or baseyaw - 58 * side
        end
    end,

    -- ============================================
    -- [49] DELAY JITTER
    -- Задержанный jitter: real меняется
    -- с задержкой относительно fake
    -- ============================================
    [49] = function(cmd)
        local ct = CurTime()
        local side = GetSide()

        local fakeJitter = math_sin(ct * 10) * 40
        local realJitter = math_sin((ct - 0.15) * 10) * 40

        return ultimate.SendPacket
            and baseyaw - 178 + realJitter
            or baseyaw + fakeJitter + 58 * side
    end,

    -- ============================================
    -- [50] ULTIMATE HYBRID
    -- Комбинация лучших техник: anti-bruteforce,
    -- desync, LBY break, freestand, micro jitter
    -- ============================================
    [50] = function(cmd)
        local ct = CurTime()
        local side = GetSide()
        local lby = GetLBY()
        local vel = me:GetVelocity():Length2D()
        local enemy, dist = GetNearestEnemy()

        -- Авто-выбор лучшего режима
        ultimate.aa.adaptiveCounter = ultimate.aa.adaptiveCounter + 1

        -- Anti-bruteforce: меняем каждые 1.5 сек
        if ct - ultimate.aa.lastAdaptiveSwitch > 1.5 then
            ultimate.aa.lastAdaptiveSwitch = ct
            ultimate.aa.adaptiveCounter = 0
        end

        local phase = ultimate.aa.adaptiveCounter % 60
        local micro = math_sin(ct * 35) * 2

        if vel > 100 then
            -- Движение: LBY abuse
            return ultimate.SendPacket
                and lby + 180 + micro
                or lby + 58 * side
        end

        if enemy and dist < 400 then
            -- Ближний бой: быстрый jitter
            local fastJit = math_sin(ct * 30) * 35
            return ultimate.SendPacket
                and baseyaw - 178 + fastJit + micro
                or baseyaw + 58 * side + micro * -1
        end

        -- Дальний бой: rotation between modes
        if phase < 15 then
            -- Backward desync
            return ultimate.SendPacket
                and baseyaw - 178 + micro
                or baseyaw + 58 * side
        elseif phase < 30 then
            -- Sideways desync
            return ultimate.SendPacket
                and baseyaw + 90 * side + micro
                or baseyaw - 90 * side
        elseif phase < 45 then
            -- Freestand
            local freeYaw = FreestandAngle()
            return ultimate.SendPacket
                and freeYaw + micro
                or freeYaw + 180
        else
            -- LBY break
            return ultimate.SendPacket
                and lby + 180 + micro
                or baseyaw + 58 * side
        end
    end,
}

do
    local pitch, yaw = 0, 0

    local pitches = {
        [1] = 89,
        [2] = -89,
        [3] = 0,
        [4] = -180,
        [5] = 180,
    }

    local mm_side = false
    local side = false
    local pitchflip = false

    local side = 1

    local function CalcPitch()
        local cfg = ultimate.cfg.vars["Pitch"]
        local x = 0

        if cfg <= 5 then return pitches[cfg] end

        if ultimate.SendPacket then
            pitchflip = not pitchflip
        end

        if cfg == 6 then
            x = pitchflip and 180 or -180
        elseif cfg == 7 then
            x = ultimate.SendPacket and 89 or -180
        elseif cfg == 8 then
            x = ultimate.cfg.vars["Custom pitch"]
        end

        return x
    end

    local function micromovement(cmd)
        if !ultimate.cfg.vars["Micromovement"] then return end
        if !me:Alive() then return end
        if !me:IsFlagSet( FL_ONGROUND ) then return end
        if cmd:KeyDown(IN_BACK) or cmd:KeyDown(IN_FORWARD) or cmd:KeyDown(IN_MOVELEFT) or cmd:KeyDown(IN_MOVERIGHT) then return end

        cmd:SetSideMove(mm_side and -15.0 or 15.0)
        mm_side = !mm_side
    end

    local function aacheck(cmd)
        if !ultimate.cfg.vars["Anti aim"] then return false end
        if cmd:KeyDown(IN_ATTACK) then return false end
        if cmd:KeyDown(IN_USE) then return false end
        if ultimate.moveType == MOVETYPE_LADDER then return false end
        if ultimate.moveType == MOVETYPE_NOCLIP then return false end

        if not me:Alive() or me:Team() == TEAM_SPECTATOR then
            return false
        end


        if ultimate.cfg.vars["Yaw base"] == 2 then
            local v = ultimate.aatarget

            if not IsValid(v) then return false end
            if not v:Alive() or v:IsDormant() then return false end

            if ultimate.cfg.vars["Ignores-Bots"] and v:IsBot() then return false end
            if ultimate.cfg.vars["Ignores-Friends"] and ultimate.cfg.friends[v:SteamID64()] then return false end
            if ultimate.cfg.vars["Ignores-Steam friends"] and v:GetFriendStatus() == "friend" then return false end
            if ultimate.cfg.vars["Ignores-Admins"] and v:IsAdmin() then return false end
            if ultimate.cfg.vars["Ignores-Frozen"] and v:IsFlagSet( FL_FROZEN ) then return false end
            if ultimate.cfg.vars["Ignores-Nodraw"] and v:IsEffectActive( EF_NODRAW ) then return false end
            if ultimate.cfg.vars["Ignores-God time"] and v:GetColor().a < 255 then return false end
            if ultimate.cfg.vars["Ignores-Driver"] and v:InVehicle() then return false end

            local iTeamLocal = ultimate.GetTeam( me )
            local iTeamEnemy = ultimate.GetTeam( v )
            if ultimate.cfg.vars["Ignores-Teammates"] and iTeamLocal == iTeamEnemy then return false end
            if ultimate.cfg.vars["Ignores-Nocliping"] and v:GetMoveType() == MOVETYPE_NOCLIP then return false end

            local priority = ultimate.cfg.priorities[v:SteamID64()] or "Medium"
            if ultimate.cfg.vars["Ignores-Low priority"] and priority == "Low" then return false end
        end

        if ultimate.cfg.binds["Anti aim"] != 0 and not ultimate.IsKeyDown(ultimate.cfg.binds["Anti aim"]) then
            return false
        end

        return true
    end

    function ultimate.AntiAim(cmd)
        local freestandsucc, freestandsafe, freestandunsafe

        if ultimate.cfg.vars["Freestanding"] then
            freestandsucc, freestandsafe, freestandunsafe = ultimate.Freestand(cmd)
        end

        if ultimate.SendPacket then
            ultimate.SwaySide = ultimate.SwaySide * -1
        end

        baseyaw = ultimate.GetBaseYaw()
        pitch = CalcPitch()
        yaw = ultimate.CalcYaw[ultimate.cfg.vars["Yaw"] ](cmd)

        if ultimate.cfg.vars["Yaw randomisation"] then
            yaw = yaw + math_random( -15, 15 )
        end

        if freestandsucc then
            yaw = ultimate.SendPacket and freestandunsafe or freestandsafe
        end

        if aacheck(cmd) then
            local pyAngle = Angle(pitch,yaw,0)

            micromovement(cmd)

            cmd:SetViewAngles(pyAngle)
            ultimate.oldYaw = pyAngle.y
        end
    end
end

