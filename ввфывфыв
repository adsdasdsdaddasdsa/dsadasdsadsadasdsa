function ultimate.AutoWall(dir, plyTarget)
    if not ultimate.activeWeapon then return false end

    local eyePos = me:EyePos()
    local weaponClass = ultimate.activeWeaponClass

    local weaponType = "unknown"
    if weaponClass:find("m9k_") then
        weaponType = "m9k"
    elseif weaponClass:find("swb_") or ultimate.swbShit[weaponClass] then
        weaponType = "swb"
    end

    local function UniversalAutowall()
        local maxDistance = 32768
        local penetrationPower = 3

        if ultimate.activeWeapon.Primary and ultimate.activeWeapon.Primary.Damage then
            if ultimate.activeWeapon.Primary.Damage > 50 then
                penetrationPower = 5
            elseif ultimate.activeWeapon.Primary.Damage > 30 then
                penetrationPower = 4
            end
        end

        local function TraceThroughWalls(startPos, direction, maxPenetrations, currentPen)
            if currentPen > maxPenetrations then return false end

            ultimate.traceStruct.start = startPos
            ultimate.traceStruct.endpos = startPos + direction * maxDistance
            ultimate.traceStruct.filter = me
            ultimate.traceStruct.mask = MASK_SHOT

            local tr = util.TraceLine(ultimate.traceStruct)

            if tr.Hit and not tr.HitSky then
                if tr.Entity == plyTarget then
                    if ultimate.cfg.vars["Ignores-Head unhitable"] then
                        return tr.HitGroup == 1
                    else
                        return true
                    end
                end

                local canPenetrate = false
                local penetrationDistance = 0

                if tr.MatType == MAT_GLASS or tr.MatType == MAT_WOOD or tr.MatType == MAT_PLASTIC then
                    canPenetrate = true
                    penetrationDistance = 50
                elseif tr.MatType == MAT_CONCRETE or tr.MatType == MAT_METAL then
                    if penetrationPower >= 4 then
                        canPenetrate = true
                        penetrationDistance = 30
                    end
                elseif tr.MatType == MAT_FLESH or tr.MatType == MAT_ALIENFLESH then
                    canPenetrate = true
                    penetrationDistance = 20
                end

                if canPenetrate and currentPen < maxPenetrations then
                    local newStart = tr.HitPos + direction * penetrationDistance
                    return TraceThroughWalls(newStart, direction, maxPenetrations, currentPen + 1)
                end
            end

            return false
        end

        return TraceThroughWalls(eyePos, dir, penetrationPower, 0)
    end

    local function ImprovedSWBAutowall()
        if ultimate.swbShit[weaponClass] then return false end

        local range = ultimate.activeWeapon.PenetrativeRange or 32768

        ultimate.traceStruct.start = eyePos
        ultimate.traceStruct.endpos = eyePos + dir * range
        ultimate.traceStruct.filter = me
        ultimate.traceStruct.mask = ultimate.swbNormal or MASK_SHOT

        local tr = util.TraceLine(ultimate.traceStruct)

        if tr.Hit and not tr.HitSky then
            local dot = -dir:Dot(tr.HitNormal)

            local minDot = 0.2
            local canPenetrate = ultimate.activeWeapon.CanPenetrate

            if not canPenetrate then
                if weaponClass:find("sniper") or weaponClass:find("rifle") then
                    canPenetrate = true
                    minDot = 0.15
                end
            end

            if canPenetrate and dot > minDot then
                local penStr = ultimate.activeWeapon.PenStr or 100
                local penMod = ultimate.activeWeapon.PenMod or 1
                local materialMultiplier = ultimate.swbPen[tr.MatType] or 1

                ultimate.traceStruct.start = tr.HitPos
                ultimate.traceStruct.endpos = tr.HitPos + dir * penStr * materialMultiplier * penMod
                ultimate.traceStruct.filter = me
                ultimate.traceStruct.mask = ultimate.swbWall or MASK_SHOT_HULL

                tr = util.TraceLine(ultimate.traceStruct)

                ultimate.traceStruct.start = tr.HitPos
                ultimate.traceStruct.endpos = tr.HitPos + dir * 5
                ultimate.traceStruct.filter = me
                ultimate.traceStruct.mask = ultimate.swbNormal or MASK_SHOT

                tr = util.TraceLine(ultimate.traceStruct)

                if tr.Hit then
                    ultimate.traceStruct.start = tr.HitPos
                    ultimate.traceStruct.endpos = tr.HitPos + dir * 10
                    ultimate.traceStruct.filter = me

                    tr = util.TraceLine(ultimate.traceStruct)
                end

                ultimate.traceStruct.start = tr.HitPos
                ultimate.traceStruct.endpos = tr.HitPos + dir * 32768
                ultimate.traceStruct.filter = me
                ultimate.traceStruct.mask = MASK_SHOT

                tr = util.TraceLine(ultimate.traceStruct)

                if tr.Entity == plyTarget then
                    if ultimate.cfg.vars["Ignores-Head unhitable"] then
                        return tr.HitGroup == 1
                    else
                        return true
                    end
                end
            end
        end

        return false
    end

    local function ImprovedM9KAutowall()
        if not ultimate.activeWeapon.Penetration then
            return UniversalAutowall()
        end

        local function BulletPenetrate(tr, bounceNum, damage)
            if damage < 1 then return false end

            local maxPenetration = 14
            local maxRicochet = 0
            local isRicochet = false

            if ultimate.m9kPenetration[ultimate.activeWeapon.Primary.Ammo] then
                maxPenetration = ultimate.m9kPenetration[ultimate.activeWeapon.Primary.Ammo]
            end

            if ultimate.m9kMaxRicochet[ultimate.activeWeapon.Primary.Ammo] then
                maxRicochet = ultimate.m9kMaxRicochet[ultimate.activeWeapon.Primary.Ammo]
            end

            if ultimate.m9kCanRicochet[ultimate.activeWeapon.Primary.Ammo] then
                isRicochet = ultimate.m9kCanRicochet[ultimate.activeWeapon.Primary.Ammo]
            end

            if tr.MatType == MAT_METAL and isRicochet then
                if ultimate.activeWeapon.Primary.Ammo != "SniperPenetratedRound" then
                    local angle = math.deg(math.acos(tr.HitNormal:Dot(dir)))
                    if angle < 25 then
                        return false
                    end
                end
            end

            if bounceNum > maxRicochet then return false end

            local penetrationDir = tr.Normal * maxPenetration

            local materialBoost = 1
            if ultimate.m9kPenMaterial[tr.MatType] then
                materialBoost = 2
            elseif tr.MatType == MAT_GLASS or tr.MatType == MAT_WOOD then
                materialBoost = 1.5
            elseif tr.MatType == MAT_FLESH then
                materialBoost = 0.8
            end

            penetrationDir = tr.Normal * (maxPenetration * materialBoost)

            ultimate.traceStruct.endpos = tr.HitPos
            ultimate.traceStruct.start = tr.HitPos + penetrationDir
            ultimate.traceStruct.mask = MASK_SHOT
            ultimate.traceStruct.filter = me

            local trace = util.TraceLine(ultimate.traceStruct)

            if trace.StartSolid or trace.Fraction >= 1 then
                return false
            end

            ultimate.traceStruct.endpos = trace.HitPos + dir * 32768
            ultimate.traceStruct.start = trace.HitPos
            ultimate.traceStruct.mask = MASK_SHOT
            ultimate.traceStruct.filter = me

            local penTrace = util.TraceLine(ultimate.traceStruct)

            if penTrace.Entity == plyTarget then
                if ultimate.cfg.vars["Ignores-Head unhitable"] then
                    return penTrace.HitGroup == 1
                else
                    return true
                end
            end

            local damageMulti = 0.5
            if ultimate.activeWeapon.Primary.Ammo == "SniperPenetratedRound" then
                damageMulti = 0.8
            elseif tr.MatType == MAT_CONCRETE or tr.MatType == MAT_METAL then
                damageMulti = 0.4
            elseif tr.MatType == MAT_WOOD or tr.MatType == MAT_PLASTIC then
                damageMulti = 0.7
            elseif tr.MatType == MAT_GLASS then
                damageMulti = 0.9
                bounceNum = bounceNum - 1
            elseif tr.MatType == MAT_FLESH or tr.MatType == MAT_ALIENFLESH then
                damageMulti = 0.6
            end

            return BulletPenetrate(penTrace, bounceNum + 1, damage * damageMulti)
        end

        ultimate.traceStruct.start = eyePos
        ultimate.traceStruct.endpos = eyePos + dir * 32768
        ultimate.traceStruct.filter = me
        ultimate.traceStruct.mask = MASK_SHOT

        local trace = util.TraceLine(ultimate.traceStruct)
        local damage = ultimate.activeWeapon.Primary and ultimate.activeWeapon.Primary.Damage or 30

        return BulletPenetrate(trace, 0, damage)
    end

    if weaponType == "m9k" then
        return ImprovedM9KAutowall()
    elseif weaponType == "swb" then
        return ImprovedSWBAutowall()
    else
        return UniversalAutowall()
    end
end

function ultimate.VisibleCheck( who, where, predticks, awalldir )
    local start = me:EyePos()

    if predticks then start = start + ( me:GetVelocity() * TickInterval ) * predticks end

    ultimate.traceStruct.start = start
	ultimate.traceStruct.endpos = where
	ultimate.traceStruct.mask = MASK_SHOT
    ultimate.traceStruct.filter = me

    local tr = TraceLine( ultimate.traceStruct )

    local canhit = tr.Entity == who or tr.Fraction == 1

    if !canhit and awalldir and ultimate.cfg.vars["Wallz"] then
        return ultimate.AutoWall( awalldir, who )
    end

    if ultimate.cfg.vars["Ignores-Head unhitable"] and tr.HitGroup != 1 then return false end

    return canhit
end

function ultimate.CanShoot( cmd )
	if not ultimate.activeWeapon then return false end
	local seq = ultimate.activeWeapon:GetSequence()

    if ultimate.cfg.binds["Aim on key"] != 0 and not ultimate.IsKeyDown( ultimate.cfg.binds["Aim on key"] ) then
        return false
    end

	if ultimate.badSweps[ ultimate.activeWeaponClass ] then
		return false
	end

    if ultimate.moveType == MOVETYPE_NOCLIP then
        return false
    end

    if ultimate.cfg.vars["Auto fire"] and cmd:KeyDown(IN_ATTACK) then
        return false
    end

	if ultimate.cfg.vars["Bullet time"] and ultimate.activeWeapon:GetNextPrimaryFire() >= ded.GetServerTime() then
		return false
	end

    if ultimate.cfg.vars["!BSendPacket Fire"] and ultimate.SendPacket then
		return false
	end

    local delay = 0
	if ultimate.cfg.vars["ShootDelay"] then
		delay = ultimate.cfg.vars["ShootDelay time"] / 1000
        return ( ded.GetServerTime() - delay ) >= ultimate.activeWeapon:GetNextPrimaryFire()
    end

    // print(ded.GetRandomSeed( cmd ))
    if ultimate.cfg.vars["Wait for seed"] and ded.GetRandomSeed( cmd ) != 134 then
        return false
    end

	return ultimate.activeWeapon:Clip1() != 0 and !ultimate.badSeqs[ seq ]
end

function ultimate.Spread( cmd, ang, spread )
	if not ultimate.activeWeapon or not ultimate.cones[ ultimate.activeWeaponClass ] then return ang end

	local dir = ded.PredictSpread( cmd, spread )

	local newangle = ang + dir:Angle()
    newangle:Normalize()

	return newangle
end

