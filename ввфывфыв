hook.Add("HUDPaint", "ultimate_draw_killstreak", function()
    if !ultimate.cfg.vars["Killstreak"] then return end
    if #ultimate.killstreak_notifications == 0 then return end

    local scrW   = ScrW()
    local scrH   = ScrH()
    local centerX = scrW / 2

    -- Самый верх но чуть ниже
    local topY = scrH * 0.07

    local notif = ultimate.killstreak_notifications[1]
    if !notif then return end

    local elapsed  = CurTime() - notif.startTime
    local progress = elapsed / notif.duration

    if progress >= 1 then
        table.remove(ultimate.killstreak_notifications, 1)
        return
    end

    -- Анимация
    if progress < 0.15 then
        notif.alpha = Lerp(progress / 0.15, 0, 255)
        notif.scale = Lerp(progress / 0.15, 0.6, 1.1)
    elseif progress < 0.22 then
        notif.scale = Lerp((progress - 0.15) / 0.07, 1.1, 1.0)
        notif.alpha = 255
    elseif progress > 0.78 then
        notif.alpha = Lerp((progress - 0.78) / 0.22, 255, 0)
        notif.scale = 1.0
    else
        notif.alpha = 255
        notif.scale = 1.0
    end

    local a     = notif.alpha
    local mcol  = ColorAlpha(notif.mainColor, a)
    local scol  = ColorAlpha(Color(220, 220, 220), a)
    local shcol = ColorAlpha(Color(0, 0, 0), a)

    -- Тряска только рампага первые 1 секунду
    local shakeX, shakeY = 0, 0
    if notif.shake and elapsed < 1.0 then
        local amt = Lerp(elapsed / 1.0, 4, 0)
        shakeX = math.random(-math.ceil(amt), math.ceil(amt))
        shakeY = math.random(-math.ceil(amt), math.ceil(amt))
    end

    -- ============================================
    -- СНАЧАЛА SUB (сверху)
    -- ============================================
    local subH = 0
    if notif.sub then
        surface.SetFont("KS_Sub")
        local sw, sh = surface.GetTextSize(notif.sub)
        subH = sh

        local sx = centerX - sw / 2
        local sy = topY

        -- Тень
        draw.SimpleText(notif.sub, "KS_Sub", sx + 1, sy + 1, shcol, TEXT_ALIGN_LEFT, TEXT_ALIGN_TOP)
        -- Текст
        draw.SimpleText(notif.sub, "KS_Sub", sx, sy, scol, TEXT_ALIGN_LEFT, TEXT_ALIGN_TOP)
    end

    -- ============================================
    -- ПОТОМ MAIN (ниже sub)
    -- ============================================
    surface.SetFont("KS_Main")
    local tw, th = surface.GetTextSize(notif.main)

    local gap = notif.sub and 6 or 0
    local mx  = centerX - tw / 2 + shakeX
    local my  = topY + subH + gap + shakeY

    -- Тень
    draw.SimpleText(notif.main, "KS_Main", mx + 2, my + 2, shcol, TEXT_ALIGN_LEFT, TEXT_ALIGN_TOP)
    -- Основной
    draw.SimpleText(notif.main, "KS_Main", mx, my, mcol, TEXT_ALIGN_LEFT, TEXT_ALIGN_TOP)

end)

