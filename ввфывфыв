function ultimate.SequenceShit(cmd)
    if not ultimate.cfg.vars["Sequence manip"] or not ultimate.IsKeyDown(ultimate.cfg.binds["Sequence manip"]) then
        if ultimate.seqshit then
            ultimate.seqshit = false
        end
        return
    end

    ultimate.seqshit = true
    ultimate.SendPacket = true

    local mode = ultimate.cfg.vars["Sequence mode"]
    local strength = ultimate.cfg.vars["Sequence strength"]
    if mode == 1 then
        ded.SetOutSequenceNr(ded.GetOutSequenceNr() + strength)
    elseif mode == 2 then
        ded.SetOutSequenceNr(ded.GetOutSequenceNr() + math_random(0, strength))
    elseif mode == 3 then
        local factor = math.sin(CurTime() * 5) * 2 // Динамический фактор
        ded.SetOutSequenceNr(ded.GetOutSequenceNr() + factor * strength)
    elseif mode == 4 then
        ded.SetOutSequenceNr(ded.GetOutSequenceNr() + 2500)
    elseif mode == 5 then
        if CurTime() > ultimate.nextm9k and bit.band(cmd:GetButtons(), IN_ATTACK) != 0 then
            ded.SetOutSequenceNr(ded.GetOutSequenceNr() + 5000)
            ultimate.nextm9k = CurTime() + 0.5
        end
    elseif mode == 6 then
        local amt = math_random(ultimate.cfg.vars["Sequence min"], ultimate.cfg.vars["Sequence max"])
        ded.SetOutSequenceNr(ded.GetOutSequenceNr() + amt)
    end

    local curack = ded.GetOutSequenceNrAck()
    local diff = curack - ultimate.prevack

    if diff == 0 then
        ultimate.numerrors = ultimate.numerrors + 1
        if ultimate.numerrors > 33 then
            print(("[ultimate] Too much lost packets, fixing (delta %d)"):format(ded.GetOutSequenceNr() - ded.GetOutSequenceNrAck()))
            ded.SetOutSequenceNr(curack)
            ultimate.numerrors = 0
        end
    else
        ultimate.numerrors = math.max(0, ultimate.numerrors - 1)
    end

    ultimate.prevack = curack
end

function ultimate.Desynculator(cmd)
    if not ultimate.cfg.vars["Desynculator manip"] or not ultimate.IsKeyDown(ultimate.cfg.binds["Desynculator manip"]) then
        if ultimate.desyncshit then
            ultimate.desyncshit = false
        end
        return
    end

    ultimate.SendPacket = true

    if ultimate.SendPacket then
        if (ultimate.seqshift > 0) then
            if (not ultimate.desyncshit) then
                local current_seq = ded.GetOutSequenceNr()
                ded.SetOutSequenceNr(current_seq + ultimate.seqshift)
                ultimate.desyncshit = true
            else
                local choke_amount = 127
                ded.SetNetChokedPackets(choke_amount)
            end
        else
            ultimate.desyncshit = false
        end
    end

    local delta = ded.GetOutSequenceNr() - ded.GetOutSequenceNrAck()
    if delta > 2000 then
        print(string.format("[Desynculator] Large gap detected (%d), resetting", delta))
        ded.SetOutSequenceNr(ded.GetOutSequenceNrAck() + 1)
        ultimate.desyncshit = false
    end
end

