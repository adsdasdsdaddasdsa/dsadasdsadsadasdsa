function ultimate.CustomSpread.rust(cmd, ang)
    if not ultimate.activeWeapon or not ultimate.activeWeapon.AimCone then
        return ang
    end

    local wpn = ultimate.activeWeapon
    local pl = LocalPlayer()

    -- Получаем точку прицеливания (без спрэда)
    local trace = util.TraceLine({
        start = pl:GetShootPos(),
        endpos = pl:GetShootPos() + ang:Forward() * 16384,
        filter = pl,
        mask = MASK_SHOT
    })

    local targetPos = trace.HitPos

    -- Для системы проектилей нужно рассчитать начальный угол с учётом гравитации
    if wpn.EnableProjectiles and wpn.Bullets == 1 then
        local bulletVelocity = wpn.BulletVelocity or 5000
        if wpn.Stats and wpn.Stats.VelocityMultiplier then
            bulletVelocity = bulletVelocity * wpn.Stats.VelocityMultiplier
        end

        -- Рассчитываем угол с учётом баллистики (гравитация 9.81 * METERS_TO_UNITS)
        local gravity = 9.81 * 52.4934 -- METERS_TO_UNITS обычно 52.4934
        local shootPos = pl:GetShootPos()
        local distance = targetPos:Distance(shootPos)

        -- Баллистическая траектория (упрощённая формула)
        local pitch = math.atan((distance * gravity) / (bulletVelocity * bulletVelocity))
        local adjustedAng = ang - Angle(math.deg(pitch) * 0.5, 0, 0)

        return adjustedAng
    end

    -- Для обычных пуль или дробовиков
    local spread = wpn.AimCone

    -- Прицеливание уменьшает спрэд
    if wpn.IronSightsDelta and wpn.IronSightsDelta > 0.1 then
        spread = Lerp(wpn.IronSightsDelta, spread, spread * 0.05)
    end

    -- Модификаторы attachments
    if wpn.Stats and wpn.Stats.AimConeMultiplier then
        spread = spread * wpn.Stats.AimConeMultiplier
    end

    -- Минимальный спрэд
    math.randomseed(cmd:CommandNumber() * 1337 + wpn:EntIndex())
    local spreadVec = math.max(spread * 16, 0.01) -- Не даём нулевой спрэд

    return ang - Angle(math.Rand(-spreadVec, spreadVec), math.Rand(-spreadVec, spreadVec), 0)
end


function ultimate.CustomSpread.arcw( cmd, ang )
    local angDir = ang:Forward()

	local seed1 = ultimate.activeWeapon:GetBurstCount()
	local seed2 = !game.SinglePlayer() and cmd:CommandNumber() or CurTime()

	local randSeed = util.SharedRandom(seed1, -1337, 1337, seed2) * (ultimate.activeWeapon:EntIndex() % 30241)
	math_randomseed(math_Round(randSeed))

	local spread = ArcCW.MOAToAcc * ultimate.activeWeapon:GetBuff("AccuracyMOA")
	local disp = ultimate.activeWeapon:GetDispersion() * ArcCW.MOAToAcc / 10

	angDir:Rotate(Angle(0, -ArcCW.StrafeTilt(ultimate.activeWeapon), 0))
	angDir = angDir - VectorRand() * disp

	local randSeed = util.SharedRandom(1, -1337, 1337, seed2) * (ultimate.activeWeapon:EntIndex() % 30241)
	math_randomseed(math_Round(randSeed))
	angDir = angDir - VectorRand() * spread

	return angDir:Angle()
end

